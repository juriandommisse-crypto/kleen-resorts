# =====================================================================
# Kleen Resorts Dashboard — voorbeeld-configuratie
# Kopieer dit bestand naar `.env.local` en vul de waarden in.
# `.env.local` staat in .gitignore en wordt NOOIT gecommit.
# =====================================================================

# Databron: "mock" (testdata, geen credentials nodig) of "live".
# Zolang dit op "mock" staat draait het dashboard volledig zonder koppelingen.
DATA_SOURCE=mock

# --- Google Sheets ---------------------------------------------------
# Service-account e-mail + private key (uit de JSON-key van Google Cloud).
# Deel beide sheets met dit e-mailadres (leesrechten).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Sheet-ID's (al bekend uit je Drive):
SHEET_ID_AD_SPEND=1Ti9fqrGCMzROHXzNuiBH1qACsZTwPWxHKSGMw_pNsL0
SHEET_ID_LEADS=1vVdNk9gsKZ2PwK5ZQX3K1RqDy_1JsqWwcX_ff_K6iVk

# --- Meta Marketing API ----------------------------------------------
# Long-lived system user token met `ads_read`.
META_ACCESS_TOKEN=
# Komma-gescheiden ad-account-ID's, met "act_"-prefix, bv: act_123,act_456
META_AD_ACCOUNT_IDS=
META_API_VERSION=v21.0

# --- Anthropic (slimme wekelijkse samenvatting) ----------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Beveiliging -----------------------------------------------------
# Laat leeg = geen login (geheime URL). Vul een wachtwoord in om een
# simpele login aan te zetten zonder iets in de code te wijzigen.
DASHBOARD_PASSWORD=

# --- Cron (wekelijkse refresh) ---------------------------------------
# Geheime sleutel die de cron-endpoint beschermt.
CRON_SECRET=
